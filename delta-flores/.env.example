# ================================
# CONFIGURACIÓN DATABASE (PostgreSQL)
# ================================
# Conexión a PostgreSQL (Docker service name)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=flores_delta_db
DB_USERNAME=flores_user
DB_PASSWORD=changeme_in_production  # ⚠️ CAMBIAR EN PRODUCCIÓN

# ================================
# CONFIGURACIÓN JWT
# ================================
# Secret para firmar tokens JWT (mínimo 64 caracteres)
# Generar con: openssl rand -hex 64
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=86400000

# ================================
# CONFIGURACIÓN MINIO (Object Storage)
# ================================
# Endpoint de MinIO (local o cloud)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin  # ⚠️ CAMBIAR EN PRODUCCIÓN
MINIO_BUCKET_NAME=flores-delta-media

# ================================
# CONFIGURACIÓN SERVIDOR
# ================================
# Puerto del backend
SERVER_PORT=8080

# Perfil de Spring (dev, staging, prod)
SPRING_PROFILES_ACTIVE=dev

# ================================
# CONFIGURACIÓN CORS (Opcional)
# ================================
# Orígenes permitidos (separados por coma)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ================================
# CONFIGURACIÓN LOGGING (Opcional)
# ================================
# Nivel de logging (TRACE, DEBUG, INFO, WARN, ERROR)
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_APP=DEBUG

# ================================
# OBSERVACIONES
# ================================
# 1. Copiar este archivo a .env antes de arrancar
# 2. NUNCA commitear .env real (solo .env.example)
# 3. Generar secrets únicos por entorno
# 4. Rotar JWT_SECRET y passwords regularmente
