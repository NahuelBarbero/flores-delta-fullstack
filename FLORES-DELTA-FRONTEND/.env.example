# ================================
# CONFIGURACIÓN API
# ================================
# URL del backend (desarrollo local)
VITE_API_URL=http://localhost:8080

# URL del backend (producción - descomentar)
# VITE_API_URL=https://api.floresdelta.com

# ================================
# CONFIGURACIÓN ENVIRONMENT
# ================================
# Modo de ejecución (development, staging, production)
# VITE_ENV_MODE=development

# ================================
# CONFIGURACIÓN ANALYTICS (Opcional)
# ================================
# Google Analytics ID
# VITE_GA_ID=G-XXXXXXXXXX

# Sentry DSN para error tracking
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ================================
# OBSERVACIONES
# ================================
# 1. Copiar a .env.local para desarrollo
# 2. Variables VITE_* son públicas (expuestas al cliente)
# 3. NUNCA poner secrets sensibles aquí
# 4. Build embebe estas variables en el bundle
